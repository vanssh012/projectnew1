{
  "expo": {
    "name": "Afterly",
    "slug": "afterly",
    "version": "1.0.0",
    "scheme": "afterly",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0E10"
    },
    "android": {
      "package": "com.afterly.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0E10"
      }
    },
    "ios": {
      "bundleIdentifier": "com.afterly.app",
      "buildNumber": "1"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3d1c334c-fc1c-4d66-bb33-70ab9b0ed936"
      }
    }
  }
}